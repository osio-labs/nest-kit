{
  "name": "@os.io/nest-kit",
  "version": "0.0.1-alpha.0",
  "description": "A modular, production-ready NestJS toolkit — Bootstrap, Auth, SaaS, and Infra integrations in a single package.",
  "keywords": [
    "nestjs",
    "nest-kit",
    "toolkit",
    "bootstrap",
    "authentication",
    "authorization",
    "saas",
    "multi-tenant",
    "logger",
    "storage",
    "stripe",
    "audit",
    "metrics",
    "typescript"
  ],
  "homepage": "https://github.com/osio-labs/nest-kit#readme",
  "bugs": {
    "url": "https://github.com/osio-labs/nest-kit/issues"
  },
  "license": "MIT",
  "author": "Wind Blade <vn.chemgio@yahoo.com> (https://github.com/osio-labs)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osio-labs/nest-kit.git"
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap/index.d.ts",
      "import": "./dist/bootstrap/index.js",
      "require": "./dist/bootstrap/index.js"
    },
    "./bootstrap/swagger": {
      "types": "./dist/bootstrap/swagger/index.d.ts",
      "import": "./dist/bootstrap/swagger/index.js",
      "require": "./dist/bootstrap/swagger/index.js"
    },
    "./bootstrap/scalar": {
      "types": "./dist/bootstrap/scalar/index.d.ts",
      "import": "./dist/bootstrap/scalar/index.js",
      "require": "./dist/bootstrap/scalar/index.js"
    },
    "./bootstrap/cache": {
      "types": "./dist/bootstrap/cache/index.d.ts",
      "import": "./dist/bootstrap/cache/index.js",
      "require": "./dist/bootstrap/cache/index.js"
    },
    "./bootstrap/typeorm": {
      "types": "./dist/bootstrap/typeorm/index.d.ts",
      "import": "./dist/bootstrap/typeorm/index.js",
      "require": "./dist/bootstrap/typeorm/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.js"
    },
    "./saas": {
      "types": "./dist/saas/index.d.ts",
      "import": "./dist/saas/index.js",
      "require": "./dist/saas/index.js"
    },
    "./infra": {
      "types": "./dist/infra/index.d.ts",
      "import": "./dist/infra/index.js",
      "require": "./dist/infra/index.js"
    },
    "./infra/logger": {
      "types": "./dist/infra/logger/index.d.ts",
      "import": "./dist/infra/logger/index.js",
      "require": "./dist/infra/logger/index.js"
    },
    "./infra/notification": {
      "types": "./dist/infra/notification/index.d.ts",
      "import": "./dist/infra/notification/index.js",
      "require": "./dist/infra/notification/index.js"
    },
    "./infra/storage": {
      "types": "./dist/infra/storage/index.d.ts",
      "import": "./dist/infra/storage/index.js",
      "require": "./dist/infra/storage/index.js"
    },
    "./infra/stripe": {
      "types": "./dist/infra/stripe/index.d.ts",
      "import": "./dist/infra/stripe/index.js",
      "require": "./dist/infra/stripe/index.js"
    },
    "./infra/audit-log": {
      "types": "./dist/infra/audit-log/index.d.ts",
      "import": "./dist/infra/audit-log/index.js",
      "require": "./dist/infra/audit-log/index.js"
    },
    "./infra/metrics": {
      "types": "./dist/infra/metrics/index.d.ts",
      "import": "./dist/infra/metrics/index.js",
      "require": "./dist/infra/metrics/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "format": "prettier --write \"packages/**/*.ts\" \"*.{md,json}\"",
    "format:check": "prettier --check \"packages/**/*.ts\" \"*.{md,json}\"",
    "lint": "eslint \"packages/**/*.ts\" --fix",
    "lint:check": "eslint \"packages/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@scalar/nestjs-api-reference": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    },
    "@scalar/nestjs-api-reference": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testMatch": [
      "<rootDir>/packages/**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "packages/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/testing": "^11.0.1",
    "@scalar/nestjs-api-reference": "^1.2.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitepress": "^1.5.0"
  }
}
